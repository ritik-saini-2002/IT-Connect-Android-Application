<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer full circle with gradient -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#50E3C2"
                android:endColor="#4A90E2"
                android:angle="45"
                android:type="linear" />
        </shape>
    </item>

    <!-- Inner transparent circle (cuts out the center) -->
    <item
        android:left="60dp"
        android:top="60dp"
        android:right="60dp"
        android:bottom="60dp">
        <shape android:shape="oval">
            <solid android:color="#000000"
                android:alpha="0" />
        </shape>
    </item>

</layer-list>