<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow HTTP to ALL private LAN ranges.
        Covers every IP you might configure as PC agent.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>