<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow cleartext HTTP — the app connects to LAN services
        (PocketBase, PC agent) via raw IP addresses, which Android's
        domain-config cannot match. PrivateNetworkInterceptor blocks
        cleartext to public IPs at the OkHttp layer instead.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
