<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="ProtectedPermissions">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.INSTALL_PACKAGES"/>
    <!-- Required for DownloadManager -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Required for foreground notification service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_REMOTE_MESSAGING" />



    <uses-feature android:name="android.hardware.camera"    android:required="false" />
    <uses-feature android:name="android.hardware.telephony" android:required="false" />

    <queries>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="content" />
        </intent>
    </queries>

    <application
        android:name=".MyApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/it_connect_logo"
        android:roundIcon="@drawable/it_connect_logo"
        android:label="Ritik Saini"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ritik_2"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="35">

        <!-- ── Entry point ────────────────────────────────── -->
        <activity
            android:name=".splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Ritik_2">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Auth ───────────────────────────────────────── -->
        <activity android:name=".login.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".registration.RegistrationActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <!-- ── Main ───────────────────────────────────────── -->
        <activity android:name=".main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <!-- ── Profile ────────────────────────────────────── -->
        <activity android:name=".profile.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".profile.profilecompletion.ProfileCompletionActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <!-- ── Features ───────────────────────────────────── -->
        <activity android:name=".contact.ContactActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <!-- FIX: Added configChanges so PC Control activities handle
             orientation changes without destroying/recreating.
             Compose observes LocalConfiguration automatically. -->
        <activity android:name=".windowscontrol.PcControlActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Ritik_2" />

        <activity android:name=".windowscontrol.pcfilebrowser.PcControlFileBrowserActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Ritik_2" />

        <activity android:name=".windowscontrol.pccontrolappdirectory.PcControlAppDirectoryActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Ritik_2" />

        <activity android:name=".windowscontrol.pctouchpad.PcControlTouchpadActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Ritik_2" />

        <activity android:name=".windowscontrol.ui.screens.PcAddStepActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Ritik_2" />

        <activity android:name=".windowscontrol.ui.screens.PcControlAdminSettingsActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Ritik_2" />

        <activity android:name=".winshare.ServerConnectActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".macnet.MACNetActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <!-- ── Admin ──────────────────────────────────────── -->
        <activity android:name=".administrator.AdministratorPanelActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".administrator.databasemanager.DatabaseManagerActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".administrator.manageuser.ManageUserActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".administrator.rolemanagement.RoleManagementActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".administrator.newusercreation.CreateUserActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".administrator.departmentmanager.DepartmentActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".administrator.companysettings.CompanySettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".administrator.reports.ReportsActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <!-- ── Chat ───────────────────────────────────────── -->
        <activity
            android:name=".chat.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Ritik_2" />
        <activity
            android:name=".chat.MemberPickerActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <!-- Background chat notification service -->

        <activity android:name=".notifications.NotificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2"/>

        <receiver
            android:name=".chat.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- KEEP your existing service, already correct -->
        <service
            android:name=".chat.ChatNotificationService"
            android:foregroundServiceType="remoteMessaging"
            android:exported="false" />

        <!-- ── Nagios Monitoring ──────────────────────────── -->
        <activity android:name=".nagios.ConnectActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />
        <activity android:name=".nagios.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Ritik_2" />

        <activity android:name=".appupdate.AppUpdateActivity"
            android:exported="false"
            android:theme="@style/Base.Theme.Ritik_2"/>

        <!-- ── File Provider ──────────────────────────────── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>